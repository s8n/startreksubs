1175
00:35:21.365 --> 00:35:23.882 position:29.05%,start align:start size:50.00% line:84.62% 
<c.white><c.mono_sans>to seal the wormhole.</c.mono_sans></c.white>

1176
00:35:23.882 --> 00:35:26.802 position:29.05%,start align:start size:50.00% line:79.29% 
<c.white><c.mono_sans>Garak will be trapped</c.mono_sans></c.white>

1177
00:35:23.882 --> 00:35:26.802 position:32.86%,start align:start size:44.29% line:84.62% 
<c.white><c.mono_sans>on the other side.</c.mono_sans></c.white>

1178
00:35:26.802 --> 00:35:28.522 position:30.95%,start align:start size:48.10% line:84.62% 
<c.white><c.mono_sans>He made a promise...</c.mono_sans></c.white>

1179
00:35:28.522 --> 00:35:31.362 position:36.67%,start align:start size:34.76% line:84.62% 
<c.white><c.mono_sans>and so did I.</c.mono_sans></c.white>

1180
00:35:31.362 --> 00:35:34.439 position:23.33%,start align:start size:61.43% line:79.29% 
<c.white><c.mono_sans>I said I would wait for him</c.mono_sans></c.white>

1181
00:35:31.362 --> 00:35:34.439 position:38.57%,start align:start size:30.95% line:84.62% 
<c.white><c.mono_sans>and I will.</c.mono_sans></c.white>

1182
00:35:37.519 --> 00:35:39.959 position:51.90%,start align:start size:38.57% line:84.62% 
<c.white><c.mono_sans>Is a promise...</c.mono_sans></c.white>

1183
00:35:39.959 --> 00:35:42.317 position:53.81%,start align:start size:30.95% line:79.29% 
<c.white><c.mono_sans>to an enemy</c.mono_sans></c.white>

1184
00:35:39.959 --> 00:35:42.317 position:53.81%,start align:start size:36.67% line:84.62% 
<c.white><c.mono_sans>of your family</c.mono_sans></c.white>

1185
00:35:42.317 --> 00:35:44.837 position:42.38%,start align:start size:46.19% line:79.29% 
<c.white><c.mono_sans>more important than</c.mono_sans></c.white>

1186
00:35:42.317 --> 00:35:44.837 position:42.38%,start align:start size:48.10% line:84.62% 
<c.white><c.mono_sans>obeying your father?</c.mono_sans></c.white>

1187
00:35:48.716 --> 00:35:51.155 position:57.62%,start align:start size:27.14% line:84.62% 
<c.white><c.mono_sans>So be it.</c.mono_sans></c.white>

1188
00:35:51.155 --> 00:35:55.474 position:44.29%,start align:start size:46.19% line:79.29% 
<c.white><c.mono_sans>Stay here if that's</c.mono_sans></c.white>

1189
00:35:51.155 --> 00:35:55.474 position:44.29%,start align:start size:36.67% line:84.62% 
<c.white><c.mono_sans>what you want.</c.mono_sans></c.white>

1190
00:35:55.474 --> 00:35:59.352 position:34.76%,start align:start size:55.71% line:84.62% 
<c.white><c.mono_sans>Stay here and be damned.</c.mono_sans></c.white>

1191
00:36:05.630 --> 00:36:07.430 position:51.90%,start align:start size:36.67% line:79.29% 
<c.white><c.mono_sans>I should never</c.mono_sans></c.white>

1192
00:36:05.630 --> 00:36:07.430 position:51.90%,start align:start size:38.57% line:84.62% 
<c.white><c.mono_sans>have come here.</c.mono_sans></c.white>

1193
00:36:07.430 --> 00:36:09.430 position:48.10%,start align:start size:42.38% line:79.29% 
<c.white><c.mono_sans>I should have let</c.mono_sans></c.white>

1194
00:36:07.430 --> 00:36:09.430 position:48.10%,start align:start size:40.48% line:84.62% 
<c.white><c.mono_sans>that monster die</c.mono_sans></c.white>

1195
00:36:09.430 --> 00:36:10.629 position:42.38%,start align:start size:48.10% line:84.62% 
<c.white><c.mono_sans>forgotten and alone.</c.mono_sans></c.white>

1196
00:36:10.629 --> 00:36:12.429 position:19.52%,start align:start size:25.24% line:79.29% 
<c.white><c.mono_sans>Frankly,</c.mono_sans></c.white>

1197
00:36:10.629 --> 00:36:12.429 position:19.52%,start align:start size:44.29% line:84.62% 
<c.white><c.mono_sans>I'm glad you came.</c.mono_sans></c.white>

