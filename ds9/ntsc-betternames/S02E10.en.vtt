<c.bg_transparent>This isn't over yet, big ears.</c.bg_transparent>

361
00:24:18.206 --> 00:24:19.249 position:50.00%,middle align:middle size:80.00% line:84.67% 
<c.bg_transparent>( panting )</c.bg_transparent>

362
00:24:19.332 --> 00:24:20.417 position:50.00%,middle align:middle size:80.00% line:84.67% 
<c.bg_transparent>( growling )</c.bg_transparent>

363
00:24:23.295 --> 00:24:24.713 position:50.00%,middle align:middle size:80.00% line:84.67% 
<c.bg_transparent>( exhales deeply )</c.bg_transparent>

