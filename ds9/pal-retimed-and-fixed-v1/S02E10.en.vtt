334
00:21:09.920 --> 00:21:12.779 position:50.00%,middle align:middle size:80.00% line:79.33% 
<c.bg_transparent>It's time to welcome your people</c.bg_transparent>
<c.bg_transparent>to the Alpha Quadrant, Haneek.</c.bg_transparent>

335
00:21:26.000 --> 00:21:28.519 position:50.00%,middle align:middle size:80.00% line:84.67% 
<c.bg_transparent>HANEEK: Come along, don't be afraid.</c.bg_transparent>

336
00:21:29.040 --> 00:21:32.319 position:50.00%,middle align:middle size:80.00% line:79.33% 
<c.bg_transparent>Come on, it's all right.</c.bg_transparent>
<c.bg_transparent>You're among friends.</c.bg_transparent>

337
00:21:32.800 --> 00:21:35.240 position:50.00%,middle align:middle size:80.00% line:79.33% 
<c.bg_transparent>Don't be afraid.</c.bg_transparent>
<c.bg_transparent>It's all right.</c.bg_transparent>

338
00:21:36.040 --> 00:21:36.799 position:50.00%,middle align:middle size:80.00% line:84.67% 
<c.bg_transparent>It's all right.</c.bg_transparent>

339
00:21:38.439 --> 00:21:40.718 position:50.00%,middle align:middle size:80.00% line:84.67% 
<c.bg_transparent>( astonished murmuring )</c.bg_transparent>

340
